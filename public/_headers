# Cloudflare Pages caching policy
# Vendor chunks (Three.js, GSAP) change rarely — long-term cache for iPad/PWA
/assets/vendor-*
  Cache-Control: public, max-age=31536000, immutable

# App JS/CSS — content-hashed, cache forever
/assets/index-*
  Cache-Control: public, max-age=31536000, immutable

# Splash screen image assets
/splash-*
  Cache-Control: public, max-age=31536000, immutable

# PWA manifest + favicon + install icons
/manifest.json
/favicon.svg
/apple-touch-icon.png
/icon-*.png
  Cache-Control: public, max-age=604800

# HTML — never cache (always revalidate)
# /*.html: matches /index.html but NOT root URL /
# /: root path — Cloudflare _headers matches on request URL, not internal file path
/
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# XML, robots — moderate cache for SEO crawlers
/sitemap.xml
/robots.txt
  Cache-Control: public, max-age=3600
